# ============================================
# ENVIRONMENT CONFIGURATION - WhatsApp API SaaS
# ============================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# DO NOT use this file directly - create .env.local with real values

# ============================================
# NODE ENVIRONMENT
# ============================================
NODE_ENV=development
# Values: development, staging, production

# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=your-strong-db-password-here-min-16-chars
POSTGRES_DB=whatsapp_saas
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full connection string (should be: postgres://USER:PASSWORD@HOST:PORT/DB)
DATABASE_URL=postgres://admin:your-strong-db-password-here-min-16-chars@db:5432/whatsapp_saas

# ============================================
# BACKEND SERVER CONFIG
# ============================================
BACKEND_PORT=3001
BACKEND_HOST=0.0.0.0
BACKEND_URL=http://localhost:3001
# For production: BACKEND_URL=https://ws-api.erickvillon.dev

# ============================================
# FRONTEND CONFIG
# ============================================
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
# For production: FRONTEND_URL=https://ws.erickvillon.dev
NEXT_PUBLIC_API_URL=/api
# Internal Docker URL for Next.js rewrites
BACKEND_INTERNAL_URL=http://backend:3001

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-64-character-random-string-minimum-do-not-use-weak-secrets-generate-new
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=your-64-character-random-refresh-secret-different-from-above
JWT_REFRESH_EXPIRY=30d

# ============================================
# API RATE LIMITING
# ============================================
API_RATE_LIMIT_WINDOW_MS=900000
# 15 minutes in milliseconds (15 * 60 * 1000)
API_RATE_LIMIT_MAX_REQUESTS=3000
# Max requests per window per IP

API_RATE_LIMIT_AUTH_WINDOW_MS=3600000
# 1 hour - stricter for auth endpoints
API_RATE_LIMIT_AUTH_MAX_REQUESTS=10
# Max login attempts per hour

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# For production: https://ws.erickvillon.dev,https://ws-api.erickvillon.dev
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-API-Key

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
# Values: debug, info, warn, error, fatal
LOG_FORMAT=json
# Values: json, pretty
PINO_LOG_LEVEL=info

# ============================================
# ENCRYPTION & SECURITY
# ============================================
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-encryption-key-for-sensitive-data-encryption
# Used for encrypting WhatsApp sessions, API keys, etc.

BACKUP_ENCRYPTION_KEY=your-64-character-backup-encryption-key-different-from-above
# Separate key for encrypted backups

# Session storage encryption
SESSION_ENCRYPTION_ENABLED=true

# ============================================
# WHATSAPP BAILEYS CONFIGURATION
# ============================================
BAILEYS_DEBUG=false
# Disable console.log spam from Baileys
BAILEYS_LOG_LEVEL=error
# Baileys: error, warn, info, debug

WHATSAPP_MESSAGE_RATE_LIMIT=10
# Max messages per minute per session

WHATSAPP_RETRY_MAX_ATTEMPTS=5
# Max retry attempts for failed messages

WHATSAPP_SESSION_IDLE_TIMEOUT=3600
# Seconds before auto-logout due to inactivity (1 hour)

# ============================================
# EMAIL CONFIGURATION (SMPT for verification)
# ============================================
EMAIL_PROVIDER=smtp
# Values: smtp, sendgrid, ses

SMTP_HOST=smtp.gmail.com
# Your email provider SMTP server

SMTP_PORT=587
# Usually 587 for TLS, 465 for SSL

SMTP_USER=your-email@gmail.com
# Example: noreply@erickvillon.dev

SMTP_PASSWORD=your-app-specific-password
# For Gmail: Use App Password, NOT your regular password

SMTP_FROM_EMAIL=noreply@erickvillon.dev
SMTP_FROM_NAME=WhatsApp API SaaS

SMTP_TLS_ENABLED=true
# Use TLS encryption

# ============================================
# OAUTH2 CONFIGURATION
# ============================================

# --- GOOGLE OAuth ---
GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/oauth/google/callback
# For production: https://ws-api.erickvillon.dev/auth/oauth/google/callback

# Phase 4 canonical names (recommended)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/auth/oauth/google/callback
# Get from: Google Cloud Console > APIs & Services > Credentials

# --- GITHUB OAuth ---
GITHUB_OAUTH_ENABLED=true
GITHUB_CLIENT_ID=your-github-oauth-app-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-secret
GITHUB_CALLBACK_URL=http://localhost:3001/auth/oauth/github/callback
# For production: https://ws-api.erickvillon.dev/auth/oauth/github/callback

# --- MICROSOFT OAuth ---
MICROSOFT_OAUTH_ENABLED=true
MICROSOFT_CLIENT_ID=your-microsoft-app-id
MICROSOFT_CLIENT_SECRET=your-microsoft-app-secret
MICROSOFT_CALLBACK_URL=http://localhost:3001/auth/oauth/microsoft/callback
# For production: https://ws-api.erickvillon.dev/auth/oauth/microsoft/callback

# --- WHATSAPP BUSINESS OAuth (Phase 4) ---
WHATSAPP_OAUTH_ENABLED=true
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCESS_TOKEN=your-system-user-access-token
WHATSAPP_BUSINESS_APP_ID=your-meta-app-id
WHATSAPP_BUSINESS_APP_SECRET=your-meta-app-secret
WHATSAPP_OAUTH_REDIRECT_URI=http://localhost:3001/auth/oauth/whatsapp/callback
# Get from: Meta Developers > WhatsApp > API Setup/System Users

# ============================================
# MULTI-FACTOR AUTHENTICATION (MFA)
# ============================================
MFA_ENABLED=true
# Enable 2FA/TOTP for user accounts

MFA_REQUIRED_FOR_ROLES=admin
# Comma-separated roles. Example: admin,manager

MFA_EMAIL_ENABLED=true
MFA_TOTP_ENABLED=true

TOTP_ISSUER=WhatsApp API SaaS
# Name shown in authenticator apps

TOTP_WINDOW=1
# Time window for TOTP validation (in 30-second intervals)

# ============================================
# ADVANCED SESSION MANAGEMENT (PHASE 4)
# ============================================
SESSION_MAX_ACTIVE_SESSIONS=5
# Max simultaneous sessions per user

SESSION_IDLE_TIMEOUT=1800
# 30 minutes in seconds

SESSION_ABSOLUTE_TIMEOUT=86400
# 24 hours in seconds

DEVICE_FINGERPRINTING_ENABLED=true
LOGIN_ANOMALY_DETECTION_ENABLED=true
IMPOSSIBLE_TRAVEL_DETECTION_ENABLED=true

# ============================================
# SECURITY HARDENING (PHASE 4)
# ============================================
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_LOCKOUT_DURATION=900
# 15 minutes in seconds

TOKEN_REVOCATION_ENABLED=true
TOKEN_REVOCATION_CLEANUP_CRON=0 */6 * * *

OAUTH_ENCRYPTION_KEY=your-64-character-random-key-for-oauth-token-encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ============================================
# AUDIT & COMPLIANCE
# ============================================
AUDIT_LOG_ENABLED=true
# Enable automatic audit logging

AUDIT_LOG_SENSITIVE_ACTIONS=true
# Log password changes, permission updates, etc.

GDPR_ENABLED=true
# Enable GDPR features: data export, deletion

DATA_RETENTION_DAYS=365
# Auto-delete non-essential logs after X days

AUTO_DELETE_AUDIT_LOGS_DAYS=2555
# 7 years for compliance (GDPR/SOC2)

# ============================================
# BACKUP & DISASTER RECOVERY
# ============================================
BACKUP_ENABLED=true
# Enable automated backups

BACKUP_SCHEDULE_CRON=0 2 * * *
# Cron expression - default: 2 AM every day
# Format: minute hour day month weekday

BACKUP_RETENTION_DAYS=30
# Keep backups for 30 days

BACKUP_COMPRESS=true
# Compress backups to save space

BACKUP_UPLOAD_S3=false
# Upload to S3 for extra redundancy (optional)

# If using S3 backup:
# AWS_S3_BUCKET=whatsapp-saas-backups
# AWS_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ============================================
# MONITORING & ERROR TRACKING
# ============================================
SENTRY_ENABLED=false
# Enable Sentry for error tracking

# SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# ============================================
# ANALYTICS (optional)
# ============================================
ANALYTICS_ENABLED=false
# Enable analytics collection

# ============================================
# FEATURE FLAGS (optional)
# ============================================
FEATURE_MFA=true
FEATURE_OAUTH=true
FEATURE_WEBHOOKS=true
FEATURE_SCHEDULER=true
FEATURE_TEMPLATES=true
FEATURE_AUDIT_LOGS=true

# ============================================
# DOKPLOY / DOCKER COMPOSE
# ============================================
COMPOSE_PROJECT_NAME=whatsapp-api-ws
# Prefix for Docker containers

COMPOSE_FILE=docker-compose.yml
# Use docker-compose.prod.yml in production

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Only set if NODE_ENV=development
DEBUG=whatsapp-api:*
# Enable debug namespace for development

SEED_DATABASE=false
# Auto-seed database with test data on startup

MOCK_EMAIL_SENDING=true
# Mock email sending in development (do not actually send)

# If EMAIL_PROVIDER=sendgrid:
# SENDGRID_API_KEY=your-sendgrid-api-key

# If EMAIL_PROVIDER=ses:
# AWS_SES_REGION=us-east-1
